APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database = default worker in compose.yaml (laravel.queue). Horizon requires redis.
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Scout: collection = in-memory (no Meilisearch). For Meilisearch also run: composer require meilisearch/meilisearch-php
SCOUT_DRIVER=collection

# -----------------------------------------------------------------------------
# Docker Compose (compose.yaml) / Laravel Sail
# On Linux or WSL: use `id -u` and `id -g`. Docker Desktop on Windows often 1000.
# -----------------------------------------------------------------------------
WWWUSER=1000
WWWGROUP=1000
APP_PORT=80
VITE_PORT=5173
NODE_VERSION=24
# 1 during docker build: write 8.8.8.8 / 1.1.1.1 into resolv.conf for apt (fixes many Docker Desktop DNS issues). Use 0 behind strict corporate DNS.
PUBLIC_BUILD_DNS=1

FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379
FORWARD_MONGODB_PORT=27017
FORWARD_MEILISEARCH_PORT=7700
FORWARD_OLLAMA_PORT=11434

SAIL_XDEBUG_MODE=develop,debug
SAIL_XDEBUG_CONFIG="client_host=host.docker.internal client_port=9003 idekey=PHPSTORM"

MONGODB_USERNAME=
MONGODB_PASSWORD=
MEILISEARCH_NO_ANALYTICS=false

# -----------------------------------------------------------------------------
# Queues / Horizon (Docker Compose)
# -----------------------------------------------------------------------------
# `docker compose up -d` starts laravel.queue, which runs `php artisan queue:work`
# (works with QUEUE_CONNECTION=database or redis). For QUEUE_CONNECTION=sync, jobs
# run inline — you can stop the queue container: docker compose stop laravel.queue
#
# Horizon only supports Redis. Set QUEUE_CONNECTION=redis, stop laravel.queue, then either:
#   ./vendor/bin/sail artisan horizon
# or add a second compose service that runs `php artisan horizon` (do not run both workers on the same redis queues).
