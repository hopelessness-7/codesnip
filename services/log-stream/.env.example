# Absolute path inside container, or relative to process.cwd() when running locally from services/log-stream/
LOG_DIR=../../storage/logs

# Single file: laravel.log
# All *.log in LOG_DIR: *  (or "all")
# Several files: laravel.log,horizon.log
LOG_FILE=*

# When LOG_FILE is * / all: which names to tail (simple patterns). Default: *.log
# Examples: *.log | laravel* | debug-*.log
LOG_GLOB=*.log

# Minimum log level for structured Laravel lines (DEBUG, INFO, NOTICE, WARNING, ERROR, …)
LOG_MIN_LEVEL=DEBUG

WS_PORT=8081
# Use a long random string in production
WS_TOKEN=dev-secret-token
